{{ 'f24-promo.js' | asset_url | script_tag }}

{%- assign col_handle = section.settings.collection | default: 'promociones-vigentes' -%}
{%- assign promo = collections[col_handle] -%}
{%- assign wa_base = section.settings.wa_url -%}
{%- comment -%} Datos vivos: contador + fecha desde la colección/metafield (sync_f24_landing.py). {%- endcomment -%}
{%- assign promo_count = promo.products_count -%}
{%- assign promo_fecha = promo.metafields.custom.promo_fecha.value | default: 'la fecha límite' -%}

<style>
  .f24p-calc{background:linear-gradient(180deg,#08090b,#0c0e12);color:#fff;padding-block:clamp(64px,7vw,100px);position:relative;overflow:hidden}
  .f24p-calc::before{content:"";position:absolute;top:-200px;right:-200px;width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(255,184,0,.12),transparent 65%);pointer-events:none}
  .f24p-calc__wrap{max-width:1180px;margin:0 auto;padding:0 clamp(14px,2vw,22px);position:relative}
  .f24p-calc__head{text-align:center;max-width:720px;margin:0 auto clamp(28px,3.4vw,44px)}
  .f24p-calc__kicker{display:inline-block;color:#ffb800;font-weight:800;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;padding:6px 12px;background:rgba(255,184,0,.1);border-radius:999px}
  .f24p-calc__h{font-weight:900;font-size:clamp(1.8rem,3.8vw,2.8rem);line-height:1.08;letter-spacing:-.02em;margin:14px 0 12px}
  .f24p-calc__h em{font-style:normal;background:linear-gradient(135deg,#ffb800,#ff6a00);-webkit-background-clip:text;background-clip:text;color:transparent}
  .f24p-calc__sub{color:rgba(255,255,255,.65);font-size:1rem;line-height:1.55}
  .f24p-calc__panel{display:grid;gap:0;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);border-radius:24px;overflow:hidden;grid-template-columns:1fr}
  @media (min-width:920px){.f24p-calc__panel{grid-template-columns:1.1fr 1fr}}
  .f24p-calc__left{padding:clamp(24px,3vw,40px);border-bottom:1px solid rgba(255,255,255,.06)}
  @media (min-width:920px){.f24p-calc__left{border-bottom:0;border-right:1px solid rgba(255,255,255,.06)}}
  .f24p-calc__label{display:block;font-size:.82rem;color:rgba(255,255,255,.55);letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px;font-weight:700}
  .f24p-calc__select-wrap{position:relative}
  .f24p-calc__select{width:100%;background:#0e1014;color:#fff;border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:14px 44px 14px 16px;font-size:1rem;appearance:none;font-weight:600;cursor:pointer;transition:border-color .2s ease}
  .f24p-calc__select:hover,.f24p-calc__select:focus{border-color:#ffb800;outline:0}
  .f24p-calc__select-wrap::after{content:"";position:absolute;right:16px;top:50%;width:10px;height:10px;border-right:2px solid #ffb800;border-bottom:2px solid #ffb800;transform:translateY(-70%) rotate(45deg);pointer-events:none}
  .f24p-calc__hero{margin-top:22px;display:flex;gap:18px;align-items:center;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:14px}
  .f24p-calc__hero img{width:96px;height:96px;border-radius:10px;object-fit:cover;background:#15171c;flex-shrink:0}
  .f24p-calc__hero__name{font-weight:700;font-size:.98rem;line-height:1.3;margin-bottom:6px}
  .f24p-calc__hero__price{color:#ffb800;font-weight:800;font-size:1.4rem}
  .f24p-calc__hero__lbl{color:rgba(255,255,255,.55);font-size:.78rem;letter-spacing:.06em;text-transform:uppercase;margin-bottom:4px}
  .f24p-calc__right{padding:clamp(24px,3vw,40px);display:flex;flex-direction:column;gap:14px}
  .f24p-calc__option{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;transition:border-color .25s ease,background .25s ease;position:relative;overflow:hidden}
  .f24p-calc__option--best{border-color:rgba(255,184,0,.5);background:linear-gradient(135deg,rgba(255,184,0,.08),rgba(255,138,0,.04))}
  .f24p-calc__option--best::before{content:"Más popular";position:absolute;top:-1px;right:14px;background:linear-gradient(135deg,#ffb800,#ff8a00);color:#0a0a0a;font-size:.66rem;font-weight:800;padding:3px 10px;border-radius:0 0 8px 8px;letter-spacing:.04em;text-transform:uppercase}
  .f24p-calc__option__lbl{font-weight:700;font-size:1rem}
  .f24p-calc__option__lbl span{display:block;color:rgba(255,255,255,.55);font-size:.78rem;font-weight:600;margin-top:2px}
  .f24p-calc__option__amt{font-weight:900;font-size:1.3rem;color:#fff;font-variant-numeric:tabular-nums}
  .f24p-calc__option--best .f24p-calc__option__amt{color:#ffb800}
  .f24p-calc__cta{margin-top:8px;display:inline-flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,#ffb800,#ff8a00);color:#0a0a0a;font-weight:800;padding:16px;border-radius:12px;text-decoration:none;transition:transform .2s ease,box-shadow .2s ease}
  .f24p-calc__cta:hover{transform:translateY(-2px);box-shadow:0 14px 36px rgba(255,138,0,.4)}
  .f24p-calc__cta svg{width:18px;height:18px}
  .f24p-calc__note{font-size:.78rem;color:rgba(255,255,255,.45);text-align:center;line-height:1.5}
</style>

<section class="f24p-calc">
  <div class="f24p-calc__wrap">
    <div class="f24p-calc__head f24p-rev">
      <span class="f24p-calc__kicker">{{ section.settings.eyebrow }}</span>
      <h2 class="f24p-calc__h">{{ section.settings.heading_pre }} <em>{{ section.settings.heading_hl }}</em></h2>
      <p class="f24p-calc__sub">{{ section.settings.subheading | replace: '[[count]]', promo_count | replace: '[[fecha]]', promo_fecha }}</p>
    </div>

    <div class="f24p-calc__panel f24p-rev" data-d="2" data-msi-calc data-msi-wa-base="{{ wa_base }}">
      <div class="f24p-calc__left">
        <label class="f24p-calc__label" for="f24-msi-sel">Elige el equipo</label>
        <div class="f24p-calc__select-wrap">
          <select id="f24-msi-sel" class="f24p-calc__select" data-msi-product>
            {%- for product in promo.products limit: 50 -%}
              {%- assign sku = product.selected_or_first_available_variant.sku | default: product.variants.first.sku -%}
              {%- assign img = product.featured_image | image_url: width: 240 -%}
              <option data-price="{{ product.price | divided_by: 100.0 }}" data-sku="{{ sku }}" data-img="{{ img }}">{{ product.title }}</option>
            {%- else -%}
              <option data-price="0">Sin productos en colección</option>
            {%- endfor -%}
          </select>
        </div>
        <div class="f24p-calc__hero">
          {%- assign first_p = promo.products.first -%}
          {%- if first_p -%}
            <img data-msi-img src="{{ first_p.featured_image | image_url: width: 240 }}" alt="">
          {%- else -%}
            <img data-msi-img src="" alt="">
          {%- endif -%}
          <div>
            <div class="f24p-calc__hero__lbl">Equipo seleccionado</div>
            <div class="f24p-calc__hero__name" data-msi-name>{{ first_p.title }}</div>
            <div class="f24p-calc__hero__lbl" style="margin-top:8px">Precio de contado</div>
            <div class="f24p-calc__hero__price" data-msi-price>—</div>
          </div>
        </div>
      </div>
      <div class="f24p-calc__right">
        <div class="f24p-calc__option">
          <div class="f24p-calc__option__lbl">3 meses <span>sin intereses · sin comisión</span></div>
          <div class="f24p-calc__option__amt" data-msi-3>—</div>
        </div>
        <div class="f24p-calc__option">
          <div class="f24p-calc__option__lbl">6 meses <span>sin intereses · sin comisión</span></div>
          <div class="f24p-calc__option__amt" data-msi-6>—</div>
        </div>
        <div class="f24p-calc__option f24p-calc__option--best">
          <div class="f24p-calc__option__lbl">9 meses <span>sin intereses · bancos seleccionados</span></div>
          <div class="f24p-calc__option__amt" data-msi-9>—</div>
        </div>
        <a href="#" data-msi-wa target="_blank" rel="noopener" class="f24p-calc__cta" data-wa data-wa-group="promo-calc">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.789-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          Cotizar este equipo a 9 MSI por WhatsApp
        </a>
        <p class="f24p-calc__note">{{ section.settings.note }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "F24 Promo · MSI Calc",
  "settings": [
    { "type": "text", "id": "collection", "label": "Colección", "default": "promociones-vigentes" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Calculadora MSI" },
    { "type": "text", "id": "heading_pre", "label": "Heading antes", "default": "Mira cuánto pagarías" },
    { "type": "text", "id": "heading_hl", "label": "Heading destacado", "default": "al mes" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Elige uno de los 8 equipos en promoción y mira el desglose mensual a 3, 6 y 9 MSI sin intereses." },
    { "type": "textarea", "id": "note", "label": "Nota legal", "default": "Cálculo orientativo. El monto exacto depende de tu banco emisor. 9 MSI aplica solo en bancos participantes — confirma con tu tarjeta antes de comprar." },
    { "type": "text", "id": "wa_url", "label": "WhatsApp base", "default": "https://wa.me/523317903630" }
  ],
  "presets": [{ "name": "F24 Promo · MSI Calculator" }]
}
{% endschema %}
