    margin-bottom: 4px;
  }
  .spk-auto-stat-value {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 24px;
    color: var(--hc-navy) !important;
    line-height: 1;
    letter-spacing: -0.02em;
