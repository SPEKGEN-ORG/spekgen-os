  .spk-auto-stat:nth-child(2) .spk-auto-stat-value { color: var(--hc-teal) !important; }
  .spk-auto-stat:nth-child(3) .spk-auto-stat-value { color: var(--hc-orange) !important; }

  /* Vertical spine with category groups */
  .spk-auto-spine {
    position: relative;
    padding-left: 36px;
  }
  .spk-auto-spine::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: linear-gradient(to bottom, var(--hc-teal), var(--hc-navy) 45%, var(--hc-orange) 75%, var(--hc-teal));
    border-radius: 2px;
  }
  .spk-auto-cat {
    position: relative;
    margin-bottom: 24px;
  }
  .spk-auto-cat:last-child { margin-bottom: 0; }
  .spk-auto-cat-header {
    position: relative;
    padding: 14px 20px;
    background: var(--hc-white);
    border: 1px solid rgba(26, 20, 100, 0.06);
    border-left: 4px solid var(--hc-teal);
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow:
      0 1px 2px rgba(26, 20, 100, 0.04),
      0 6px 18px rgba(26, 20, 100, 0.06);
    margin-bottom: 10px;
  }
  /* Spine dot + connector line */
  .spk-auto-cat-header::before {
    content: '';
    position: absolute;
    left: -30px;
    top: 50%;
    width: 22px;
    height: 2px;
    background: var(--hc-teal);
    transform: translateY(-50%);
  }
  .spk-auto-cat-header::after {
    content: '';
    position: absolute;
    left: -36px;
    top: 50%;
    width: 14px;
    height: 14px;
    background: var(--hc-white);
    border: 3px solid var(--hc-teal);
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow: 0 0 0 3px rgba(26, 155, 140, 0.12);
  }
  .spk-auto-cat-header.accent-navy { border-left-color: var(--hc-navy); }
  .spk-auto-cat-header.accent-navy::before { background: var(--hc-navy); }
  .spk-auto-cat-header.accent-navy::after { border-color: var(--hc-navy); box-shadow: 0 0 0 3px rgba(26, 20, 100, 0.12); }
  .spk-auto-cat-header.accent-orange { border-left-color: var(--hc-orange); }
  .spk-auto-cat-header.accent-orange::before { background: var(--hc-orange); }
  .spk-auto-cat-header.accent-orange::after { border-color: var(--hc-orange); box-shadow: 0 0 0 3px rgba(232, 133, 46, 0.12); }

  .spk-auto-cat-name {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--hc-navy) !important;
  }
  .spk-auto-cat-header.accent-navy .spk-auto-cat-name { color: var(--hc-navy) !important; }
  .spk-auto-cat-header.accent-orange .spk-auto-cat-name { color: var(--hc-orange) !important; }
  .spk-auto-cat-header .spk-auto-cat-name { color: var(--hc-teal) !important; }
  .spk-auto-cat-header.accent-navy .spk-auto-cat-name { color: var(--hc-navy) !important; }
  .spk-auto-cat-badge {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 9px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(26, 155, 140, 0.1);
    color: var(--hc-teal) !important;
    border: 1px solid rgba(26, 155, 140, 0.25);
  }
  .spk-auto-cat-header.accent-navy .spk-auto-cat-badge {
    background: rgba(26, 20, 100, 0.08);
    color: var(--hc-navy) !important;
    border-color: rgba(26, 20, 100, 0.2);
  }
  .spk-auto-cat-header.accent-orange .spk-auto-cat-badge {
    background: rgba(232, 133, 46, 0.1);
    color: var(--hc-orange) !important;
    border-color: rgba(232, 133, 46, 0.3);
