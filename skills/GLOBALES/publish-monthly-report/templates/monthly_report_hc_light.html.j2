    text-transform: uppercase;
    color: var(--hc-teal) !important;
    margin-bottom: 8px;
    display: block;
  }
  .spk-auto-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 24px;
    color: var(--hc-navy) !important;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .spk-auto-intro {
    font-size: 14px;
    color: var(--hc-navy-55) !important;
