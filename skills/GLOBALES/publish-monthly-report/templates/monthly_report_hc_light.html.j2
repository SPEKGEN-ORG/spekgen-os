  .spk-ff-ticket-label {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--hc-teal) !important;
    margin-bottom: 8px;
  }
  .spk-ff-ticket-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 20px;
    color: var(--hc-cream) !important;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .spk-ff-ticket-desc {
