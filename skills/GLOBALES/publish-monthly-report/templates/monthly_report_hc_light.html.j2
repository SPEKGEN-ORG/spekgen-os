  /* ========== AUTOMATION ECOSYSTEM (spine layout) ========== */
  .spk-auto {
    margin-top: 36px;
    padding: 36px 40px 40px;
    background: var(--hc-cream);
    border: 1px solid rgba(26, 20, 100, 0.06);
