<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ client.name }} · Reporte {{ period.label }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  /* =========================================================
     Healthy Chuchos — Monthly Report (light theme · HC brand)
     Scoped to #spekgen-prospect-wrap · low-spec with :where()
     ========================================================= */
  :where(#spekgen-prospect-wrap) {
    /* HC brand palette */
    --hc-cream: #FFFCEF;
    --hc-cream-dark: #F5F0DD;
    --hc-white: #FFFFFF;
    --hc-navy: #1A1464;
    --hc-navy-55: rgba(26, 20, 100, 0.55);
    --hc-navy-35: rgba(26, 20, 100, 0.35);
    --hc-navy-12: rgba(26, 20, 100, 0.12);
    --hc-navy-06: rgba(26, 20, 100, 0.06);
    --hc-orange: #E8852E;
    --hc-orange-soft: rgba(232, 133, 46, 0.12);
    --hc-teal: #1A9B8C;
    --hc-teal-soft: rgba(26, 155, 140, 0.12);

    /* Product colors */
    --hc-artri: #42838F;
    --hc-relax: #97A25A;
    --hc-gastro: #B5382E;
    --hc-omega: #7B3FAE;

    /* Semantic */
    --hc-success: #1A9B8C;
    --hc-warn: #E8852E;
    --hc-danger: #B5382E;

    /* Typography */
    --font-head: 'Nunito', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    --font-body: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
  }

  #spekgen-prospect-wrap {
    background: var(--hc-cream);
    color: var(--hc-navy);
    font-family: var(--font-body);
    line-height: 1.6;
    padding: 32px 0 80px;
    min-height: 100vh;
  }

  #spekgen-prospect-wrap :where(*) { box-sizing: border-box; }
  #spekgen-prospect-wrap :where(img) { max-width: 100%; display: block; }
  #spekgen-prospect-wrap :where(p) { margin: 0 0 12px; }
  #spekgen-prospect-wrap :where(h1, h2, h3, h4) {
    font-family: var(--font-head);
    font-weight: 900;
    margin: 0;
    color: var(--hc-navy) !important;
    letter-spacing: -0.02em;
  }

  .spk-report {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ========== HERO ========== */
  .spk-hero {
    background: var(--hc-white);
    border-radius: 24px;
    padding: 48px 48px 44px;
    border: 1px solid var(--hc-navy-12);
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }
  .spk-hero::before {
    content: "";
    position: absolute;
    top: -40px;
    right: -40px;
    width: 260px;
    height: 260px;
    background: var(--hc-orange-soft);
    border-radius: 50%;
    z-index: 0;
  }
  .spk-hero::after {
    content: "";
    position: absolute;
    bottom: -60px;
    left: -60px;
    width: 220px;
    height: 220px;
    background: var(--hc-teal-soft);
    border-radius: 50%;
    z-index: 0;
  }
  .spk-hero-inner { position: relative; z-index: 1; }

  .spk-cobrand {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 28px;
  }
  .spk-cobrand-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--hc-white);
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--hc-navy-12);
  }
  .spk-cobrand-logo img { max-height: 32px; width: auto; }
  .spk-cobrand-logo.hc img { max-height: 44px; }
  .spk-cobrand-x {
    color: var(--hc-navy-35) !important;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 18px;
  }

  .spk-hero-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: var(--hc-orange);
    color: var(--hc-cream) !important;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 20px;
  }
  .spk-hero-title {
    font-size: 48px;
    line-height: 1.05;
    margin-bottom: 14px;
  }
  .spk-hero-title .hl { color: var(--hc-teal) !important; }
  .spk-hero-period {
    font-size: 16px;
    color: var(--hc-navy-55) !important;
    font-weight: 500;
    margin-bottom: 22px;
  }
  .spk-hero-lede {
    font-size: 16px;
    color: var(--hc-navy-55) !important;
    max-width: 720px;
    line-height: 1.65;
  }

  /* ========== SECTION BASE ========== */
  .spk-section {
    background: var(--hc-white);
    border: 1px solid var(--hc-navy-12);
    border-radius: 20px;
    padding: 40px 44px;
    margin-bottom: 28px;
  }
  .spk-section-eyebrow {
    display: inline-block;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--hc-orange) !important;
    margin-bottom: 10px;
  }
  .spk-section-title {
    font-size: 30px;
    line-height: 1.15;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .spk-section-intro {
    font-size: 15px;
    color: var(--hc-navy-55) !important;
    line-height: 1.7;
    max-width: 820px;
    margin-bottom: 28px;
  }

  /* ========== INVESTMENT ========== */
  .spk-inv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }
  .spk-inv-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: center;
    padding: 20px 24px;
    background: var(--hc-cream);
    border: 1px solid var(--hc-navy-12);
    border-radius: 14px;
    border-left: 4px solid var(--hc-orange);
  }
  .spk-inv-label {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 16px;
    color: var(--hc-navy) !important;
    margin-bottom: 4px;
  }
  .spk-inv-desc {
    font-size: 13px;
    color: var(--hc-navy-55) !important;
    line-height: 1.6;
  }
  .spk-inv-amount {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 22px;
    color: var(--hc-navy) !important;
    white-space: nowrap;
  }
  .spk-inv-amount::after {
    content: " MXN";
    font-size: 12px;
    font-weight: 700;
    color: var(--hc-navy-35) !important;
    letter-spacing: 0.5px;
  }
  .spk-inv-total {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    padding: 22px 26px;
    background: var(--hc-navy);
    border-radius: 14px;
    margin-top: 6px;
  }
  .spk-inv-total-label {
    color: var(--hc-cream) !important;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .spk-inv-total-amount {
    color: var(--hc-cream) !important;
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 28px;
  }
  .spk-inv-total-amount::after {
    content: " MXN";
    font-size: 13px;
    color: rgba(255, 252, 239, 0.6) !important;
    font-weight: 600;
  }

  /* Budget highlight */
  .spk-budget-hl {
    margin-top: 28px;
    padding: 26px 28px;
    background: var(--hc-orange-soft);
    border: 2px solid var(--hc-orange);
    border-radius: 16px;
  }
  .spk-budget-hl-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .spk-budget-hl-label {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 18px;
    color: var(--hc-navy) !important;
  }
  .spk-budget-hl-nums {
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 800;
    color: var(--hc-navy) !important;
  }
  .spk-budget-hl-nums .used { color: var(--hc-orange) !important; }
  .spk-budget-hl-nums .sep { color: var(--hc-navy-35) !important; margin: 0 6px; }
  .spk-budget-hl-bar {
    height: 12px;
    background: rgba(26, 20, 100, 0.08);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .spk-budget-hl-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--hc-orange), #FF9F45);
    border-radius: 999px;
  }
  .spk-budget-hl-note {
    font-size: 13px;
    color: var(--hc-navy-55) !important;
    line-height: 1.6;
  }

  /* ========== STRATEGY / TIMELINE ========== */
  .spk-strategy-body {
    font-size: 15px;
    color: var(--hc-navy-55) !important;
    line-height: 1.75;
    margin-bottom: 28px;
    max-width: 820px;
  }
  .spk-timeline {
    position: relative;
    padding-left: 28px;
  }
  .spk-timeline::before {
    content: "";
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(to bottom, var(--hc-orange), var(--hc-teal));
  }
  .spk-timeline-item {
    position: relative;
    padding: 4px 0 18px;
  }
  .spk-timeline-item::before {
    content: "";
    position: absolute;
    left: -26px;
    top: 8px;
    width: 16px;
    height: 16px;
    background: var(--hc-orange);
    border: 3px solid var(--hc-white);
    box-shadow: 0 0 0 2px var(--hc-orange);
    border-radius: 50%;
  }
  .spk-timeline-date {
    display: inline-block;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 12px;
    color: var(--hc-teal) !important;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 3px;
  }
  .spk-timeline-event {
    font-size: 14px;
    color: var(--hc-navy) !important;
    font-weight: 500;
    line-height: 1.55;
  }

  /* ========== SALES TABLE ========== */
  .spk-sales-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-end;
    gap: 20px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .spk-sales-total-box {
    background: var(--hc-teal);
    padding: 14px 24px;
    border-radius: 14px;
    text-align: right;
  }
  .spk-sales-total-label {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 11px;
    color: rgba(255, 252, 239, 0.85) !important;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .spk-sales-total-amount {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 26px;
    color: var(--hc-cream) !important;
  }
  .spk-sales-total-amount::after {
    content: " MXN";
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 252, 239, 0.7) !important;
  }

  .spk-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--hc-white);
    border: 1px solid var(--hc-navy-12);
    border-radius: 14px;
    overflow: hidden;
  }
  .spk-table :where(th, td) {
    padding: 14px 16px;
    text-align: left;
    font-size: 13px;
    border-bottom: 1px solid var(--hc-navy-12);
    color: var(--hc-navy) !important;
  }
  .spk-table :where(th) {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--hc-navy-55) !important;
    background: var(--hc-cream);
  }
  .spk-table tr:last-child :where(td) { border-bottom: 0; }
  .spk-table .order { font-family: var(--font-head); font-weight: 800; color: var(--hc-teal) !important; }
  .spk-table .amount {
    font-family: var(--font-head);
    font-weight: 800;
    color: var(--hc-navy) !important;
    text-align: right;
    white-space: nowrap;
  }
  .spk-honest-note {
    margin-top: 22px;
    padding: 18px 22px;
    background: var(--hc-cream);
    border-left: 4px solid var(--hc-teal);
    border-radius: 10px;
    font-size: 14px;
    color: var(--hc-navy-55) !important;
    line-height: 1.7;
  }

  /* ========== KPI GRID ========== */
  .spk-kpi-grid {
    display: grid;
    gap: 14px;
    margin-bottom: 26px;
  }
  .spk-kpi {
    background: var(--hc-cream);
    border: 1px solid var(--hc-navy-12);
    border-radius: 14px;
    padding: 20px 22px;
  }
  .spk-kpi-label {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--hc-navy-55) !important;
    margin-bottom: 8px;
  }
  .spk-kpi-value {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 30px;
    line-height: 1;
    color: var(--hc-navy) !important;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }
  .spk-kpi-sub {
    font-size: 12px;
    color: var(--hc-navy-55) !important;
    line-height: 1.5;
  }

  /* ========== ROI block ========== */
  .spk-roi {
    margin-top: 26px;
    padding: 28px;
    background: linear-gradient(135deg, var(--hc-teal-soft), var(--hc-orange-soft));
    border: 1px solid var(--hc-navy-12);
    border-radius: 16px;
  }
  .spk-roi-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 20px;
    color: var(--hc-navy) !important;
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }
  .spk-roi-grid {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 14px;
    align-items: stretch;
    margin-bottom: 16px;
  }
  .spk-roi-col {
    padding: 20px 22px;
    background: var(--hc-white);
    border: 1px solid var(--hc-navy-12);
    border-radius: 12px;
  }
  .spk-roi-col.invest { border-top: 3px solid var(--hc-orange); }
  .spk-roi-col.gen { border-top: 3px solid var(--hc-teal); }
  .spk-roi-col-label {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--hc-navy-55) !important;
    margin-bottom: 8px;
  }
  .spk-roi-col-value {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 34px;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .spk-roi-col.invest .spk-roi-col-value { color: var(--hc-orange) !important; }
  .spk-roi-col.gen .spk-roi-col-value { color: var(--hc-teal) !important; }
  .spk-roi-col-value::after {
    content: " MXN";
    font-size: 12px;
    font-weight: 600;
    color: var(--hc-navy-35) !important;
  }
  .spk-roi-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 900;
    color: var(--hc-navy-35) !important;
  }
  .spk-roi-footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .spk-roi-metric {
    background: var(--hc-white);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--hc-navy-12);
  }
  .spk-roi-metric-label {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--hc-navy-55) !important;
    margin-bottom: 4px;
  }
  .spk-roi-metric-value {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 22px;
    color: var(--hc-navy) !important;
    line-height: 1.1;
  }
  .spk-roi-metric-value.positive { color: var(--hc-teal) !important; }
  .spk-roi-note {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px dashed var(--hc-navy-12);
    font-size: 13px;
    color: var(--hc-navy-55) !important;
    line-height: 1.65;
  }

  /* ========== ADS GALLERY (inspirada en PDF) ========== */
  .spk-ads-wrap { margin-top: 28px; }
  .spk-ads-wrap-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 20px;
    color: var(--hc-navy) !important;
    margin-bottom: 8px;
  }
  .spk-ads-wrap-intro {
    font-size: 14px;
    color: var(--hc-navy-55) !important;
    line-height: 1.7;
    margin-bottom: 20px;
    max-width: 780px;
  }
  .spk-ads-list { display: grid; gap: 12px; }
  .spk-ad-row {
    display: grid;
    grid-template-columns: 50px 88px 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 14px 18px;
    background: var(--hc-white);
    border: 1px solid var(--hc-navy-12);
    border-radius: 14px;
    border-left: 4px solid var(--ad-color, var(--hc-orange));
    transition: all 0.15s;
  }
  .spk-ad-row:hover { background: var(--hc-cream); }
  .spk-ad-code {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 18px;
    color: var(--ad-color, var(--hc-orange)) !important;
    text-align: center;
    letter-spacing: -0.02em;
  }
  .spk-ad-thumb {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    background: var(--hc-navy-06);
  }
  .spk-ad-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .spk-ad-info { min-width: 0; }
  .spk-ad-product-pill {
    display: inline-block;
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 10px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--hc-white) !important;
    background: var(--ad-color, var(--hc-orange));
    padding: 3px 10px;
    border-radius: 999px;
    margin-bottom: 5px;
  }
  .spk-ad-title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 15px;
    color: var(--hc-navy) !important;
    margin-bottom: 2px;
  }
  .spk-ad-hook {
    font-size: 12px;
    color: var(--hc-navy-55) !important;
    font-style: italic;
    line-height: 1.5;
  }
  .spk-ad-meta {
    font-size: 11px;
    color: var(--hc-navy-35) !important;
    font-weight: 500;
    margin-top: 4px;
  }
  .spk-ad-meta-sub {
    font-size: 10.5px;
    color: var(--hc-navy-35) !important;
    font-weight: 400;
    margin-top: 3px;
    font-style: italic;
  }
  .spk-ad-wci {
    text-align: right;
    background: var(--hc-teal);
    padding: 6px 12px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .spk-ad-wci-label {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(255, 252, 239, 0.85) !important;
    display: block;
    line-height: 1;
    margin-bottom: 1px;
  }
  .spk-ad-wci-value {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 14px;
    color: var(--hc-cream) !important;
    line-height: 1;
  }

  /* ========== PIVOT EXPLAINER ========== */
  .spk-pivot {
    margin-top: 26px;
    margin-bottom: 26px;
    padding: 28px;
    background: linear-gradient(135deg, var(--hc-orange-soft), var(--hc-teal-soft));
    border: 1px solid var(--hc-navy-12);
    border-radius: 16px;
  }
  .spk-pivot-title {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 18px;
    color: var(--hc-navy) !important;
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }
  .spk-pivot-points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 18px;
  }
  .spk-pivot-point {
    padding: 18px 20px;
    background: var(--hc-white);
    border: 1px solid var(--hc-navy-12);
    border-radius: 12px;
  }
  .spk-pivot-label {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 13px;
    color: var(--hc-orange) !important;
