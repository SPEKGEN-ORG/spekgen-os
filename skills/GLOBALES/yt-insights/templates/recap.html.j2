<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8"/>
<title>RECAP — {{ title }}</title>
<style>
  @page {
    size: A4;
    margin: 12mm;
    background: #0F0F14;
  }
  * { box-sizing: border-box; }
  html, body {
    background: #0F0F14;
    color: #E5E5EA;
    font-family: -apple-system, "SF Pro Display", "Inter", system-ui, sans-serif;
    margin: 0; padding: 0;
    -webkit-font-smoothing: antialiased;
  }

  .recap-header {
    background: linear-gradient(135deg, #1A1024 0%, #0F0F14 100%);
    border-bottom: 2px solid #8B5CF6;
    padding: 12pt 14pt;
    margin-bottom: 10pt;
  }
  .kicker {
    font-size: 7pt;
    color: #8B5CF6;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    margin-bottom: 4pt;
  }
  .recap-title {
    font-size: 15pt;
    color: #FFFFFF;
    font-weight: 700;
    margin: 0 0 3pt 0;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .recap-meta {
    font-size: 7.5pt;
    color: #8E8E96;
  }
  .recap-meta a { color: #8B5CF6; text-decoration: none; }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 10pt;
    padding: 0 12pt;
    font-size: 9pt;
    line-height: 1.5;
  }
  .panel {
    background: #14141C;
    border: 1px solid #2A2A36;
    border-radius: 6pt;
    padding: 10pt 12pt;
  }
  .panel h2 {
    font-size: 9pt;
    color: #8B5CF6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 6pt 0;
    padding-bottom: 4pt;
    border-bottom: 1px solid #2A2A36;
    font-weight: 700;
  }
  .panel h3 {
    font-size: 9pt;
    color: #C5BAEC;
    margin: 10pt 0 4pt 0;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .panel h3:first-of-type { margin-top: 0; }
  .panel ul, .panel ol {
    margin: 3pt 0 6pt 0;
    padding-left: 16pt;
  }
  .panel li { margin-bottom: 5pt; }
  .panel li::marker { color: #8B5CF6; font-weight: 700; }
  .panel p { margin: 0 0 5pt 0; }
  .panel strong { color: #FFFFFF; }
  .panel em { color: #C5BAEC; font-style: italic; }
  .panel code {
    background: #1A1A24;
    padding: 0 3pt;
    border-radius: 2pt;
    font-family: "SF Mono", monospace;
    font-size: 8pt;
    border: 1px solid #2A2A36;
  }
  .panel a { color: #8B5CF6; text-decoration: none; }
  .panel hr { border: none; border-top: 1px solid #2A2A36; margin: 6pt 0; }

  .ideas-list .why {
    color: #8E8E96;
    font-weight: 400;
    font-size: 8.5pt;
  }

  .footer {
    margin: 14pt 12pt 0 12pt;
    padding-top: 6pt;
    border-top: 1px solid #2A2A36;
    font-size: 7pt;
    color: #6B6B74;
    display: flex;
    justify-content: space-between;
  }
  .footer code {
    background: #1A1A24;
    padding: 0 3pt;
    border-radius: 2pt;
    font-family: "SF Mono", monospace;
    color: #C5BAEC;
  }
</style>
</head>
<body>
  <div class="recap-header">
    <div class="kicker">RECAP · YT VAULT · 1 página</div>
    <h1 class="recap-title">{{ title }}</h1>
    <div class="recap-meta">{{ kicker }} · <a href="{{ url }}">{{ url }}</a></div>
  </div>

  <div class="grid">
    <div class="panel">
      <h2>TL;DR</h2>
      {{ tldr | safe }}
    </div>
    <div class="panel">
      <h2>Ideas para @gibran.alonzo.ecom</h2>
      {{ ideas | safe }}
    </div>
  </div>

  <div class="footer">
    <span><code>{{ slug }}</code></span>
    <span>SPK - 18. YT VAULT · skill /yt-insights</span>
  </div>
</body>
</html>
