# SPEKGEN OS — Template de variables de entorno
# Copia este archivo a .env (en tu home o por carpeta de cliente) y llena los valores reales.
# NUNCA commitees .env. Está en .gitignore.

# === ANCHOR (opcional) ===
# Si los scripts no encuentran "01. CLIENTS OFFICIAL" automáticamente, define aquí la ruta absoluta.
# SPEKGEN_ROOT=/Users/tuusuario/Library/CloudStorage/GoogleDrive-tu@email/My Drive/01. CLIENTS OFFICIAL
# SPEKGEN_ROOT=G:/My Drive/01. CLIENTS OFFICIAL

# === GITHUB ===
# GH_TOKEN=ghp_...

# === META / FACEBOOK ===
# META_TOKEN=  # SPEKGEN Agency token unificado (HC/GR/LF/MG/Gibran Ecom comparten)
# META_AD_ACCOUNT_HC=act_...
# META_AD_ACCOUNT_LF=act_...
# META_AD_ACCOUNT_GR=act_...
# META_AD_ACCOUNT_MG=act_...
# META_BM_AGENCIA=2131750914244150

# === SHOPIFY (por cliente) ===
# HC_SHOPIFY_STORE=healthychuchos.myshopify.com
# HC_SHOPIFY_TOKEN=shpat_...
# LF_SHOPIFY_STORE=
# LF_SHOPIFY_TOKEN=
# GR_SHOPIFY_STORE=greenray.com.mx
# GR_SHOPIFY_TOKEN=
# F24_SHOPIFY_STORE=0mtky1-q6.myshopify.com
# F24_SHOPIFY_TOKEN=
# SPEKGEN_SHOPIFY_STORE=yca1z0-wf.myshopify.com
# SPEKGEN_SHOPIFY_TOKEN=

# === GHL (GoHighLevel) ===
# GHL_API_KEY_HC=
# GHL_API_KEY_LF=
# GHL_API_KEY_GR=
# GHL_API_KEY_MG=
# GHL_API_KEY_SPEKGEN=

# === SUPABASE (Content Hub bucket post-media) ===
# SUPABASE_URL=https://wjlwpfaogjpeqgyxxnwa.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# === EMAIL / GMAIL SMTP (outreach@spekgen.com) ===
# GMAIL_USER=outreach@spekgen.com
# GMAIL_APP_PASSWORD=

# === APIs DE ENRICHMENT / DATA ===
# APIFY_TOKEN=
# APOLLO_API_KEY=                      # enrichment de emails para outreach prospects
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# === OUTREACH PROSPECTOS (spekgen-prospectos repo) ===
# GOOGLE_MAPS_API_KEY=                 # Places API — lead harvester (lapaz + gdl)
# SPEKGEN_GMAIL_APP_PASSWORD=          # alias de GMAIL_APP_PASSWORD, usado por _tools/generate_daily.py
# IMAP_USERNAME=spekgen.ai@gmail.com   # opcional, solo si corres replies-check
# IMAP_PASSWORD=                       # opcional, solo si corres replies-check

# === IMAGE / VIDEO GEN ===
# GEMINI_API_KEY=
# HIGGSFIELD_TOKEN=
# KLINGAI_USERNAME=
# KLINGAI_PASSWORD=

# === MAKE ===
